{
  "functions": {
    "source": "functions",
    "runtime": "nodejs20",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log"
    ]
  },
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "safechat-7f27d",
          "appId": "1:884836591001:android:b11589968a636b33685f08",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "safechat-7f27d",
          "appId": "1:884836591001:ios:8fab308dcc74ba9d685f08",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "macos": {
        "default": {
          "projectId": "safechat-7f27d",
          "appId": "1:884836591001:ios:b4e00c274e34a22c685f08",
          "uploadDebugSymbols": false,
          "fileOutput": "macos/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "safechat-7f27d",
          "configurations": {
            "android": "1:884836591001:android:b11589968a636b33685f08",
            "ios": "1:884836591001:ios:8fab308dcc74ba9d685f08",
            "macos": "1:884836591001:ios:b4e00c274e34a22c685f08",
            "web": "1:884836591001:web:7314d4a17d39f091685f08",
            "windows": "1:884836591001:web:c1821f2ff6f16d5f685f08"
          }
        }
      }
    }
  }
}